# Copy to .env and edit to taste; or `export` these in your shell profile.
# All variables are optional — defaults assume the layout described in README.md
# (repo at $(pwd), Slippi assets under ~/data/ssbm).

# Root for Slippi assets (ISO, extracted AppImage, replays). Used to derive the
# defaults below; override individual paths if your layout differs.
# HAL_SSBM_HOME=$HOME/data/ssbm

# HAL_REPO_DIR=/path/to/hal
# HAL_ISO_PATH=$HAL_SSBM_HOME/ssbm.ciso
# HAL_EMULATOR_PATH=$HAL_SSBM_HOME/squashfs-root/AppRun
# HAL_REPLAY_DIR=$HAL_SSBM_HOME/replays
